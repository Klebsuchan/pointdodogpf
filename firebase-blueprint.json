{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store products catalogue",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["categoryId", "name", "price"]
    },
    "Category": {
      "title": "Category",
      "description": "Store categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "StoreSettings": {
      "title": "Store Settings",
      "description": "Store settings like whatsappNumber",
      "type": "object",
      "properties": {
        "whatsappNumber": { "type": "string" }
      },
      "required": ["whatsappNumber"]
    },
    "UserCheckoutInfo": {
      "title": "User Checkout Info",
      "description": "User checkout profile details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "street": { "type": "string" },
        "neighborhood": { "type": "string" },
        "reference": { "type": "string" },
        "deliveryMethod": { "type": "string" },
        "payment": { "type": "string" },
        "needsChange": { "type": "boolean" },
        "changeFor": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders history record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "deliveryMethod": { "type": "string" },
        "street": { "type": "string" },
        "neighborhood": { "type": "string" },
        "reference": { "type": "string" },
        "payment": { "type": "string" },
        "needsChange": { "type": "boolean" },
        "changeFor": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["userId", "userName", "items", "total", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products available in the store"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories for products"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/StoreSettings" },
      "description": "Global store settings"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserCheckoutInfo" },
      "description": "User specific delivery details"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer order records"
    }
  }
}
