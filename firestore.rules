rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // Catch-all default deny
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'braian.kleber.camargo@gmail.com';
    }

    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProduct(data) {
      let hasRequired = data.keys().hasAll(['categoryId', 'name', 'price']);
      let validCategoryId = data.categoryId is string && data.categoryId.size() <= 128;
      let validName = data.name is string && data.name.size() <= 200 && data.name.size() > 0;
      let validPrice = data.price is number && data.price >= 0;
      let validDescription = !('description' in data) || (data.description is string && data.description.size() <= 1000);
      let validImageUrl = !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000);
      
      return hasRequired && validCategoryId && validName && validPrice && validDescription && validImageUrl;
    }

    function isValidCategory(data) {
      let hasRequired = data.keys().hasAll(['name']);
      let validName = data.name is string && data.name.size() <= 100 && data.name.size() > 0;
      
      return hasRequired && validName;
    }

    function isValidStoreSettings(data) {
      let hasRequired = data.keys().hasAll(['whatsappNumber']);
      let validWhatsappNumber = data.whatsappNumber is string && data.whatsappNumber.size() <= 50 && data.whatsappNumber.size() > 0;
      
      return hasRequired && validWhatsappNumber;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
